# Gateway API key (used for OpenAI-compatible upstream authentication)
GATEWAY_API_KEY=replace-me

# Qwen (DashScope compatible-mode)
QWEN_BASE_URL=http://127.0.0.1:8000/v1
QWEN_API_KEY=local-main
QWEN_MODEL=replace-with-vllm-model-id

# StepFun
STEP_BASE_URL=https://api.stepfun.com/step_plan/v1
STEP_API_KEY=replace-me
STEP_MODEL=step-3.7-flash

# Server
GATEWAY_HOST=127.0.0.1
GATEWAY_PORT=9000

# Product API -> Gateway boundary
COFOUNDER_GATEWAY_URL=http://127.0.0.1:9000
COFOUNDER_GATEWAY_API_KEY=replace-me
PRODUCT_DATA_DIR=data
PRODUCT_MAX_ARTIFACT_BYTES=1048576

# Request timeout (seconds)
REQUEST_TIMEOUT_SECONDS=300

# Audit log directory
AUDIT_DIR=data/audit
